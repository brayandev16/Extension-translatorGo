{
  "manifest_version": 3,
  "name": "Doc Translator",
  "description": "Translate technical documentation in-place with AI or Google Translate. BYOK.",
  "version": "1.0.0",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options/index.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-DxaPlscA.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/pdf-viewer/*",
        "pdf.worker.min.mjs",
        "assets/jsx-runtime-BOFgHXMK.js",
        "assets/client-C4xAqAfa.js",
        "assets/storage-D9zGGJ5f.js",
        "assets/index.tsx-CoCf7PBj.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
